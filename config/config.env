#
# Docker Configuration
#

# The name of the Docker container file
CONTAINERFILE=Containerfile

# The base image for the Docker container
BASE_IMAGE=archlinux

# The version of the base image
BASE_VERSION="base-devel-20250112.0.297543"

# Docker restart policy
DOCKER_RESTART=always

# Docker Hub username
DOCKER_USERNAME=atrawog

# Docker image name
DOCKER_IMAGE=guru-meditation

# Docker group ID
DOCKER_GID=957 

#
# User Configuration
#

# Username for the user inside the container
USER_NAME="atrawog"

# User ID for the user inside the container
USER_UID=1000

# Group ID for the user inside the container
USER_GID=1000

#
# Git Configuration
#

# Git username
GIT_USERNAME="atrawog"

# Git email address
GIT_EMAIL="atrawog@gmail.com"

#
# SSH Configuration
#

# Path to the SSH authentication socket
SSH_AUTH_SOCK=/ssh-agent

#
# Software Versions
#

PIXI_VERSION=v0.40.0 

#
# Arch Linux Packages
#

# Base packages for Arch Linux
ARCH_BASE="git fastfetch sudo opentofu iotop htop openssh curl libvirt wget sysstat docker docker-buildx docker-compose qemu-base iproute2 just pwgen helm"

# AI-related packages for Arch Linux
ARCH_AI="cuda cudnn ollama ollama-cuda nvidia-utils nvtop"

# Extra packages for Arch Linux
ARCH_EXTRA="gocryptfs sshfs fuse3 minikube supervisor" 

# Testing packages for Arch Linux
ARCH_TESTING="istio"

#
# Libvirt Configuration
#

# Hostname for the Libvirt host
LIBVIRT_HOST=a

# Username for the Libvirt host
LIBVIRT_USER=atrawog

# Default URI for Libvirt
LIBVIRT_DEFAULT_URI="qemu+ssh://${USER_NAME}@${LIBVIRT_HOST}/system"

#
# Ollama Configuration
#
# Host and port for Ollama
OLLAMA_HOST="127.0.0.1:11434" 

# Path to Ollama models
OLLAMA_MODELS="/workspace/data/models/ollama"

# Keep-alive duration for Ollama
OLLAMA_KEEP_ALIVE="5m"

# Enable or disable debug mode for Ollama
OLLAMA_DEBUG="true"

# CUDA Configuration
CUDA_VISIBLE_DEVICES=0

# Huggingface
HF_HOME="/workspace/data/models/huggingface"

#
# Host Configuration
#

# Hostname for the container
HOSTNAME=gurum 


#
# Supervisord
#

# Enable or disable JupyterBook service
JUPYTERBOOK_ENABLE=false

# Enable or disable JupyterHub service
JUPYTERHUB_ENABLE=true

# Enable or disable Ollama service
OLLAMA_ENABLE=false