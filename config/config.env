# Docker Configuration
# Configuration related to Docker containers
CONTAINERFILE=Containerfile
BASE_IMAGE=archlinux
BASE_VERSION="base-devel-20250112.0.297543"
DOCKER_RESTART=always
DOCKER_USERNAME=atrawog
DOCKER_IMAGE=guru-meditation
DOCKER_GID=957

# User Configuration
# User-specific settings
USER_NAME="atrawog"
USER_UID=1000
USER_GID=1000

# Git Configuration
# Git user settings
GIT_USERNAME="atrawog"
GIT_EMAIL="atrawog@gmail.com"

# SSH Configuration
# SSH agent settings
DEVC_SSH_AUTH_SOCK=/ssh-agent

# Software Versions
# Version information for various software
PIXI_VERSION=v0.40.0

# Arch Linux Packages
# List of packages to be installed on Arch Linux
ARCH_BASE="git fastfetch sudo opentofu iotop htop openssh curl libvirt wget sysstat docker docker-buildx docker-compose qemu-base iproute2 just"
ARCH_AI="cuda cudnn ollama ollama-cuda nvidia-utils nvtop"
#ARCH_AI="cuda cudnn nvidia-utils nvtop"
ARCH_EXTRA="gocryptfs sshfs fuse3 minikube supervisor"
ARCH_TESTING=""

# Libvirt Configuration
# Configuration for Libvirt virtualization
LIBVIRT_HOST=a
LIBVIRT_USER=atrawog
LIBVIRT_DEFAULT_URI="qemu+ssh://${USER_NAME}@${LIBVIRT_HOST}/system"

# Ollama Configuration
# Settings for Ollama AI
OLLAMA_HOST="0.0.0.0:11434"
OLLAMA_MODELS="/workspace/data/models/ollama"
OLLAMA_KEEP_ALIVE="5m"
OLLAMA_DEBUG="true"

# CUDA Configuration
# CUDA settings
CUDA_VISIBLE_DEVICES=0

# Host Configuration
# Host-specific settings
HOSTNAME=gurum

# Feature Toggles
# Enable or disable specific features
JUPYTERHUB_ENABLE=true
OLLAMA_ENABLE=true