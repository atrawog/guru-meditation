{
    
    "mergeBehavior": "overwrite",
    "indexPath": "/workspace/.continue/index",
    "models": [
        {
            "title": "DeepSeek Coder 2 16B",
            "provider": "ollama",
            "model": "deepseek-coder-v2:16b"
        },
        {
            "title": "Llama 3.1 8B",
            "provider": "ollama",
            "model": "llama3.1:8b"
        }
    ],
    "tabAutocompleteModel": {
        "title": "Qwen2.5-Coder 1.5B",
        "model": "qwen2.5-coder:1.5b-base",
        "provider": "ollama"
    },
    "tabAutocompleteOptions": {
        "maxPromptTokens": 400,
        "prefixPercentage": 0.5,
        "multilineCompletions": "always"
    },
    "embeddingsProvider": {
    "provider": "ollama",
    "model": "nomic-embed-text"
    },

    "docs": [
        {
        "title": "continue",
        "startUrl": "https://docs.continue.dev/"
        },
        {
            "title": "kubernetes",
            "startUrl": "https://kubernetes.io/docs/home/"
        },
        {
            "title": "k3s",
            "startUrl": "https://docs.k3s.io/"
        },
        {
            "title": "rook",
            "startUrl": "https://rook.github.io/docs/rook/latest-release/Getting-Started/intro/"
        },
        {
            "title": "longhorn",
            "startUrl": "https://longhorn.io/docs/1.7.2/"
        },
        {
            "title": "jupyterhub",
            "startUrl": "https://jupyterhub.readthedocs.io/en/stable/"
        },
        {
            "title": "huggingface",
            "startUrl": "https://huggingface.co/docs"
        },
        {
            "title": "arch",
            "startUrl": "https://wiki.archlinux.org/title/Table_of_contents"
        },
        {
            "title": "bazzite",
            "startUrl": "https://docs.bazzite.gg/"
        }
    ]
}